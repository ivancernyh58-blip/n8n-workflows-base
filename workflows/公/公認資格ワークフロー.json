    {
      "id": "01ab76dc-b0df-4561-bfc2-09116faa7d50",
      "name": "Format: Slack Message",
      "type": "n8n-nodes-base.code",
      "position": [
        -2128,
        1040
      ],
      "parameters": {
        "jsCode": "return items.map((item, index) => {\n\n  let data;\n\n  try {\n    data = JSON.parse(item.json.output);\n  } catch (e) {\n    data = item.json;\n  }\n\n  const text = `■ ${index + 1}\n\n${data.link || 'リンクなし'}\n\n【要約】\n${data.summary || 'なし'}\n\n【対象】\n${data.target || 'なし'}\n\n【活用例】\n${data.use_case || 'なし'}\n\n【メリット】\n${data.merit || 'なし'}\n\n【デメリット】\n${data.demerit || 'なし'}\n`;\n\n  return {\n    json: {\n      text: text\n    }\n  };\n\n});"
      },
      "typeVersion": 2
    },
