      "parameters": {
        "jsCode": "// Aggregate fetched records for Employee Survey Response Router.\nconst items = $input.all();\nreturn items.map((it) => ({ json: { ...it.json, processed: true } }));\n",
        "mode": "runOnceForAllItems"
