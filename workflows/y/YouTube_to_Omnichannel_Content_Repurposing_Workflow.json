      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const action = $input.item.json.body.actions[0].action_id;\nconst prev = $('🔧 Prepare Data').item.json;\n\nlet result = {\n  blog_approved: prev.blog_approved,\n  linkedin_approved: prev.linkedin_approved,\n  twitter_approved: prev.twitter_approved,\n  instagram_approved: prev.instagram_approved,\n  action: action.startsWith('approve_') ? 'approve_platform' : action,\n  content_data: $('🔍 Parse JSON').item.json.content_data,\n  transcript_text: prev.transcript_text,\n  video_url: prev.video_url,\n  revision_count: prev.revision_count\n};\n\nif (action === 'approve_blog') result.blog_approved = true;\nif (action === 'approve_linkedin') result.linkedin_approved = true;\nif (action === 'approve_twitter') result.twitter_approved = true;\nif (action === 'approve_instagram') result.instagram_approved = true;\n\nreturn result;"
      },
      "typeVersion": 2
