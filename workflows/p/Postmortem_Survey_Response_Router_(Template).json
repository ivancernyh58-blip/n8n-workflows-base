      "parameters": {
        "jsCode": "// Aggregate fetched records for Postmortem Survey Response Router.\nconst items = $input.all();\nreturn items.map((it) => ({ json: { ...it.json, processed: true } }));\n",
        "mode": "runOnceForAllItems"
      }
