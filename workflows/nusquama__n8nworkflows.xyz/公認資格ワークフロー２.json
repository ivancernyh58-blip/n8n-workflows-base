      "id": "047dd732-a9ac-4f4b-ba94-d5af7fdf109d",
      "name": "Format: Slack Message Output",
      "type": "n8n-nodes-base.code",
      "position": [
        7632,
        1024
      ],
      "parameters": {
        "jsCode": "return items.map((item, index) => {\n\n  let data;\n\n  try {\n    data = JSON.parse(item.json.output);\n  } catch (e) {\n    data = item.json;\n  }\n\n  const text = `■ ${index + 1}\n\n${data.link || 'リンクなし'}\n\n【要約】\n${data.summary || 'なし'}\n\n【対象】\n${data.target || 'なし'}\n\n【活用例】\n${data.use_case || 'なし'}\n\n【効果】\n${data.effect || 'なし'}\n`;\n\n  return {\n    json: {\n      text: text,\n      target: data.target || '',\n      use_case: data.use_case || '',\n      effect: data.effect || ''\n    }\n  };\n\n});"
      },
      "typeVersion": 2
    },
