    {
      "id": "85aa2f06-9bf4-4293-b2a1-488588cd00a5",
      "name": "Format: Build Final Voice Script",
      "type": "n8n-nodes-base.code",
      "position": [
        8160,
        1376
      ],
      "parameters": {
        "jsCode": "const segments = $input.first().json.text || [];\n\nconst body = segments\n  .map((item, index) => {\n    let raw = item.json || item;\n\n    let text = '';\n\n    try {\n      // ```json を除去\n      const cleaned = raw\n        .replace(/```json/g, '')\n        .replace(/```/g, '')\n        .trim();\n\n      const parsed = JSON.parse(cleaned);\n      text = parsed.radio_text || '';\n    } catch (e) {\n      text = '';\n    }\n\n    return `第${index + 1}件目です。${text}`;\n  })\n  .join('\\n\\n');\n\nconst script = `\nおはようございます。\n\n今日の仕事術・生産性ニュースを、聞きやすくまとめてお届けします。\n\n${body}\n\n以上、今日の注目ニュースでした。\n気になった記事は、あとでSlackのリンクから確認してみてください。\n`.trim();\n\nreturn [\n  {\n    json: {\n      script,\n      date: new Date().toISOString().slice(0, 10),\n    }\n  }\n];"
      },
      "typeVersion": 2
    },
