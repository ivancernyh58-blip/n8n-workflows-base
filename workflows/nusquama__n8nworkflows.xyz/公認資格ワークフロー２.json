    {
      "id": "32635686-b534-4099-b2c8-b389ef9eab1b",
      "name": "Extract: Clean Text from HTML",
      "type": "n8n-nodes-base.code",
      "position": [
        6992,
        1168
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const html = $json.data || '';\n\n// ==============================\n// ① 商品URL抽出（←ここ追加）\n// ==============================\nconst links = [...html.matchAll(/href=\"(https?:\\/\\/[^\"]+)\"/g)]\n  .map(m => m[1]);\n\nconst productUrl = links.find(url =>\n  url.includes('amazon') ||\n  url.includes('rakuten') ||\n  url.includes('store') ||\n  url.includes('shop')\n);\n\n// ==============================\n// ② テキスト抽出（既存処理）\n// ==============================\nlet text = html\n  .replace(/<script[\\s\\S]*?<\\/script>/gi, '')\n  .replace(/<style[\\s\\S]*?<\\/style>/gi, '')\n  .replace(/<[^>]*>/g, '')\n  .replace(/[^ぁ-んァ-ン一-龥a-zA-Z0-9。、！？\\s]/g, '');\n\ntext = text\n  .split('\\n')\n  .map(line => line.trim())\n  .filter(line => line.length > 20)\n  .join('\\n');\n\ntext = text.replace(/\\s+/g, ' ').trim().slice(0, 3000);\n\n// ==============================\n// ③ 出力\n// ==============================\nreturn {\n  json: {\n    link: $('Prepare: Extract Article Link for HTTP').item.json.link,\n    cleanText: text,\n    product_url: productUrl || ''\n  }\n};"
      },
      "typeVersion": 2
    },
