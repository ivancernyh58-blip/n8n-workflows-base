    {
      "id": "8704f6f7-87f3-4ebf-8cd3-d8f481daf60b",
      "name": "Execute Custom Code",
      "type": "n8n-nodes-base.code",
      "position": [
        4032,
        3024
      ],
      "parameters": {
        "jsCode": "for (const item of items) {\n  const youtubeUrl = item.json['YT Url'];\n\n  if (typeof youtubeUrl === 'string' && youtubeUrl.includes('=')) {\n    // Find the index of the last '=' character\n    const lastEqualsIndex = youtubeUrl.lastIndexOf('=');\n    // Extract the substring after the last '='\n    const videoId = youtubeUrl.substring(lastEqualsIndex + 1);\n    // Add the extracted videoId to the item's JSON data\n    item.json.videoId = videoId;\n  } else {\n    // Handle cases where 'YT Url' is not a string or doesn't contain '='\n    // You might want to set it to null, an empty string, or throw an error\n    item.json.videoId = null;\n  }\n}\n\nreturn items;"
      },
      "typeVersion": 2
    },
